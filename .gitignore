# =============================================================================
# Cimmeria (Stargate Worlds Emulator) - .gitignore
# =============================================================================

# =============================================================================
# Build Outputs
# =============================================================================
# Compiled executables and runtime DLLs
bin64/
!bin64/.keep

# Compiled static/dynamic libraries
lib64/
!lib64/.keep
lib/
!lib/.keep
!frontend/src/lib/
!frontend/src/lib/**

# Object files and intermediates
*.obj
*.o
*.res
*.iobj
*.ipdb
*.ilk
*.exp

# =============================================================================
# Third-Party Dependencies (vendored - 724MB)
# =============================================================================
# These should be fetched/built separately, not stored in git.
# Run setup-dependencies.ps1 to download and set up all dependencies.
# See CLAUDE.md or setup-dependencies.ps1 for full dependency details.
external/*
!external/boost/
external/boost/*
!external/boost/user-config.jam
!external/soci/
external/soci/*
!external/soci/src/
external/soci/src/*
!external/soci/src/core/
external/soci/src/core/*
!external/soci/src/core/soci-platform.h

# =============================================================================
# Visual Studio
# =============================================================================
.vs/
*.vcxproj.user
*.sln.user
*.suo
*.ncb
*.sdf
*.opensdf
*.VC.db
*.VC.opendb
ipch/
*.aps
*.cachefile
*.psess
*.vsp
*.vspx
*.sap
*.e2e

# Build configuration directories (VS intermediate output)
Debug/
Release/
MinSizeRel/
RelWithDebInfo/
UnoptRelease/
x64/
Win32/

# =============================================================================
# Runtime / Logs
# =============================================================================
logs/**
!logs/*/.keep

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/

# =============================================================================
# OS Files
# =============================================================================
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
._*
.Spotlight-V100
.Trashes

# =============================================================================
# Editor / IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.bak
*.orig
*.tmp

# =============================================================================
# Local Config Overrides (credentials, local dev settings)
# =============================================================================
# The checked-in config/ files are templates with defaults.
# Use *.local for machine-specific overrides containing real credentials.
config/*.local
*.local.config
.env
.env.*

# =============================================================================
# Server Runtime (PostgreSQL data, logs)
# =============================================================================
server/
# Allow the server binary crate
!crates/server/

# =============================================================================
# PostgreSQL Server Distribution (runtime only, not needed for compilation)
# =============================================================================
external/postgresql_server/

# =============================================================================
# Rust / Cargo Build Artifacts
# =============================================================================
target/

# =============================================================================
# Qt / qmake Build Artifacts (tools/ServerEd)
# =============================================================================
tools/ServerEd/.qmake.stash
tools/ServerEd/Makefile
tools/ServerEd/Makefile.Debug
tools/ServerEd/Makefile.Release
tools/ServerEd/ui_*.h
cimmeria-server.exe
notify.log
src-tauri/gen/schemas/windows-schema.json

# =============================================================================
# SGW Launcher (crates/launcher)
# =============================================================================
crates/launcher/binaries/*.exe
crates/launcher/gen/schemas/windows-schema.json


frontend/node_modules/*
docs/~$content-engine-data-template.xlsx
