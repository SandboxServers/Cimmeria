{
  "productName": "Cimmeria Content Editor",
  "version": "0.1.0",
  "identifier": "com.cimmeria.content-editor",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build"
  },
  "app": {
