            <Arg>   WSTRING  <ArgName>MovieName</ArgName></Arg>
        </cancelMovie>
        
    </CellMethods>

    <ClientMethods>
    
        <!-- Starts the Defeat Window -->
        <onBeginAidWait>
        <Arg>   INT32  <ArgName>TimeToAid</ArgName></Arg>           <!-- Time to "Respawn/Release" -->
            <Arg> ARRAY <of> Respawner </of> <ArgName> respawners </ArgName> </Arg>
        </onBeginAidWait>
        
        <!-- Closes the Defeat Window -->
        <onEndAidWait>
        </onEndAidWait>
        
        <!-- Give the client feedback on attempted DHD use -->
        <onDHDReply>
            <Arg>          WSTRING       <ArgName>aMessage</ArgName></Arg>
        </onDHDReply>
        
        <onKnownAbilitiesUpdate>            
            <Arg>   ARRAY<of>INT32</of>   <ArgName>AbilityData</ArgName> </Arg>
        </onKnownAbilitiesUpdate>
      
        <!-- Update time of day information -->
        <onTimeofDay>
            <Arg>   FLOAT   <ArgName>Time</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>Wind</ArgName></Arg>
            <Arg>   INT8    <ArgName>Weather</ArgName></Arg>
        </onTimeofDay>
      
		<!-- Update the client perf stats late -->
		<onOverridePerfStatsRate>
			<Arg>	INT32	<ArgName>NewIntervalMS</ArgName></Arg>
		</onOverridePerfStatsRate>
	  
        <!-- Prompts the initial interaction screen with a list of topics -->
        <onInitialInteraction>
            <Arg> ARRAY <of>DialogChoices</of> <ArgName>Choices</ArgName></Arg>
        </onInitialInteraction>
     
      <!-- Starts a dialog with the player --> 
      <onDialogDisplay>
        <Arg>   INT32   <ArgName>   EntityId    </ArgName></Arg>
        <Arg>   INT32   <ArgName>   DialogID    </ArgName></Arg>
        <Arg>   INT32   <ArgName>   MissionFlags</ArgName></Arg>
        <Arg>   UINT8   <ArgName>   IsImmediate	</ArgName></Arg>
        <Arg>   INT32   <ArgName>   aMissionId  </ArgName></Arg>
      </onDialogDisplay>
      
      <onVaultOpen>
