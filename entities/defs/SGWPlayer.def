            <Arg>   ARRAY <of> MAILBOX </of>  </Arg>  <!-- enemy squad mailboxes -->
        </startSquadDuel>

        <duelAbort>
        </duelAbort>

        <onDuelDefeat>
            <Arg>    INT8    </Arg> <!-- reason -->
        </onDuelDefeat>

        <registerDuelMarker>
            <Arg>    MAILBOX    </Arg> <!-- SGWDuelMarker base mailbox -->
        </registerDuelMarker>

        <startDuel>
            <Arg>    MAILBOX    </Arg> <!-- SGWDuelMarker base mailbox -->
        </startDuel>

        <duelForfeit>
            <Exposed/>
        </duelForfeit>

        <perfStats>
            <Arg>   FLOAT   <ArgName>AvgFPS</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>MinFPS</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>MaxFPS</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>InBytes</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>OutBytes</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>InPackets</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>OutPackets</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>AvgLag</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>MinLag</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>MaxLag</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>resends</ArgName></Arg>
            <Arg>   FLOAT   <ArgName>AppearanceJobs</ArgName></Arg>
        </perfStats>
        <!-- Called by the client to request to start a trade with another entity -->
        <tradeRequest>
            <Exposed/>
            <Arg>       INT32               <ArgName>EntityId</ArgName></Arg>
            <Arg>       LocalTradeProposal  <ArgName>LocalProposal</ArgName></Arg>
        </tradeRequest>

        <!-- Called by another entity to request to start a trade with this entity -->
        <tradeRequestFromEntity>
            <Arg>       INT32               </Arg>
            <Arg>       RemoteTradeProposal </Arg>
        </tradeRequestFromEntity>

        <!-- Called by the client to request that the current trade is cancelled -->
        <tradeRequestCancel>
            <Exposed/>
            <Arg>       INT32       <ArgName>EntityId</ArgName></Arg>
        </tradeRequestCancel>

        <!-- Called by the client to update what this entity currently has in their trade window -->
        <tradeUpdateProposal>
            <Exposed/>
            <Arg>   INT32               <ArgName> EntityId        </ArgName> </Arg>
            <Arg>   LocalTradeProposal  <ArgName> LocalProposal   </ArgName> </Arg>
        </tradeUpdateProposal>
        
        <!-- Called by another entity to update the status of the trade -->
        <updateTradeState>
            <Arg>   MAILBOX             </Arg>
            <Arg>   INT32               </Arg>
            <Arg>   RemoteTradeProposal </Arg>
        </updateTradeState>
        
        <!-- Called by the client to update the state of their trade locks -->
        <tradeLockState>
            <Exposed/>
            <Arg>   INT32               <ArgName> LocalVersionId  </ArgName> </Arg>
            <Arg>   INT32               <ArgName> RemoteVersionId </ArgName> </Arg>
            <Arg>   INT8               <ArgName> LockState       </ArgName> </Arg>
        </tradeLockState>

	<!-- Called by the space creator when a player comes close. -->
	<learnPlayerRespawner>
            <Arg>   INT32   </Arg>                      <!-- Entity Id who is starting this greet window with the player -->
	</learnPlayerRespawner>
        
        <!-- Called by another entity to update thier current lock state -->
        <updateTradeLockState>
            <Arg>   INT32   </Arg>
            <Arg>   INT32   </Arg>
            <Arg>   INT32   </Arg>
        </updateTradeLockState>
                
        <!-- Called by another entity to request the trade to be cancelled -->
        <tradeCancel>
            <Arg>       INT32       <ArgName> EntityId </ArgName></Arg>
        </tradeCancel>

        <setPvPFlag>
            <Arg>    INT8    </Arg> <!-- flag value -->
            <Arg>    INT8    </Arg> <!-- should do strike team logic -->
        </setPvPFlag>
        
        <startPvPTimer>
