        <!-- called when a fellow squad member transported to their destination -->
        <onSquadMemberRingTransportFinished>
            <Arg>   INT32   </Arg> <!-- Generic region destination -->
        </onSquadMemberRingTransportFinished>
        
        <onReady>
        </onReady>
            
