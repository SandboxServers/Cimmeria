            <Exposed/>
            <Arg>    INT8     <ArgName> aResponse  </ArgName>    </Arg>
        </sendDuelResponse>

        <duelChallenge>
            <Arg>    MAILBOX                   </Arg>  <!-- entity base mailbox -->
            <Arg>    ARRAY <of> MAILBOX </of>  </Arg>  <!-- squad entity base mailboxes -->
        </duelChallenge>

        <duelResponse>
            <Arg>    MAILBOX                    </Arg>  <!-- entity base mailbox -->
            <Arg>    INT8                       </Arg>  <!-- reponse -->
            <Arg>    ARRAY <of> MAILBOX </of>   </Arg>  <!-- squad entity base mailboxes -->
        </duelResponse>

