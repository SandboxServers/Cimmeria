        </launchOrganizationCreation>

        <onUpdateDiscipline>
            <Arg>   INT32    <ArgName>  aDisciplineSeqId  </ArgName>  </Arg>  
            <Arg>   INT32    <ArgName>  aExpertise        </ArgName>  </Arg>  
        </onUpdateDiscipline>
        
        <onDisciplineRespec>
        </onDisciplineRespec>

        <onUpdateRacialParadigmLevel>
            <Arg>   INT32    <ArgName>  aRacialParadigmId  </ArgName>  </Arg>  
            <Arg>   INT8     <ArgName>  aLevel             </ArgName>  </Arg>  
        </onUpdateRacialParadigmLevel>

        <onUpdateKnownCrafts>
            <Arg>   ARRAY <of> INT32 </of>  <ArgName>  aCraftList  </ArgName>  </Arg>  
        </onUpdateKnownCrafts>

        <onUpdateCraftingOptions>
            <Arg>  CraftingOptions <ArgName> aOptions </ArgName> </Arg>
        </onUpdateCraftingOptions>
      
        <onAbilityTreeInfo>
            <Arg>   ARRAY <of> ARRAY <of> INT32 </of> </of> <ArgName> AbilityLists   </ArgName>  </Arg>
        </onAbilityTreeInfo>
        
        <!-- Sent to client when server wants to challenge the client.
           - Client must respond with onClientChallengeResponse with the
           - correct values in order to avoid being marked as incompliant.
          -->
        <onClientChallenge>
		<Arg> INT32 <ArgName>aClientChallenge</ArgName></Arg>
        	<Arg> INT32 <ArgName>aChallengeType</ArgName></Arg>
        	<Arg> WSTRING <ArgName>aChallengeObject</ArgName></Arg>
        	<Arg> INT32 <ArgName>aChallengeID1</ArgName></Arg>
        	<Arg> INT32 <ArgName>aChallengeID2</ArgName></Arg>
        </onClientChallenge>

        <onDuelChallenge>
            <Arg>  INT32                   <ArgName>  aEntityId   </ArgName>  </Arg> <!-- entity id of who initiated the duel challenge -->
            <Arg>  ARRAY <of> INT32 </of>  <ArgName>  aSquadList  </ArgName>  </Arg> <!-- list of squad members of challenger -->
        </onDuelChallenge>

        <!-- Updates the current state of the trade window on the client -->
        <onTradeState>
            <Arg>   INT32               <ArgName>EntityId</ArgName></Arg>
            <Arg>   LocalTradeProposal  <ArgName>LocalProposal</ArgName></Arg>
            <Arg>   RemoteTradeProposal <ArgName>RemoteProposal</ArgName></Arg>
        </onTradeState>
        
        <!-- Informs the client that the current trade has been cancelled -->
        <onTradeResults>
            <Arg>   INT32   <ArgName> EntityId </ArgName>   </Arg>
            <Arg>   INT32   <ArgName> Result   </ArgName>   </Arg>
        </onTradeResults>

	<onSpaceQueued>
		<Arg> WSTRING <ArgName>aSpaceName</ArgName></Arg>
	</onSpaceQueued>

	<onSpaceQueueReady>
		<Arg> WSTRING <ArgName>aSpaceName</ArgName></Arg>
	</onSpaceQueueReady>

        <onRemoteEntityCreate>
            <Arg>    INT32    <ArgName>  aEntityId    </ArgName>  </Arg>
            <Arg>    WSTRING  <ArgName>  aEntityType  </ArgName>  </Arg>
            <Arg>    VECTOR3  <ArgName>  aPosition    </ArgName>  </Arg>
            <Arg>    INT32    <ArgName>  aWorldId     </ArgName>  </Arg>
            <Arg>    INT32    <ArgName>  aSpaceId     </ArgName>  </Arg>
        </onRemoteEntityCreate>

        <onRemoteEntityMove>
            <Arg>    INT32    <ArgName>  aEntityId    </ArgName>  </Arg>
            <Arg>    VECTOR3  <ArgName>  aPosition    </ArgName>  </Arg>
            <Arg>    INT32    <ArgName>  aWorldId     </ArgName>  </Arg>
            <Arg>    INT32    <ArgName>  aSpaceId     </ArgName>  </Arg>
        </onRemoteEntityMove>

        <onRemoteEntityRemove>
            <Arg>    INT32    <ArgName>  aEntityId    </ArgName>  </Arg>
        </onRemoteEntityRemove>

        <onDuelEntitiesSet>
            <Arg>    ARRAY <of> INT32 </of>    <ArgName>  aEntityList    </ArgName>  </Arg>
        </onDuelEntitiesSet>

        <onDuelEntitiesRemove>
            <Arg>    INT32    <ArgName>  aEntityId    </ArgName>  </Arg>
        </onDuelEntitiesRemove>

        <onDuelEntitiesClear>
        </onDuelEntitiesClear>

        <onThreatenedMobsUpdate>
            <Arg>   INT32   <ArgName>   EntityId    </ArgName>  </Arg>
            <Arg>   UINT8   <ArgName>   HasThreat   </ArgName>  </Arg>
        </onThreatenedMobsUpdate>
        
        <onPlayMovie>
            <Arg>   WSTRING		<ArgName>   MovieName   </ArgName>  </Arg>
            <Arg>   UINT8		<ArgName>   FullScreen  </ArgName>  </Arg>
        </onPlayMovie>
        
        <onCancelMovie>
            <Arg>   WSTRING		<ArgName>   MovieName   </ArgName>  </Arg>
            <Arg>   INT32		<ArgName>   EntityId    </ArgName>  </Arg>
        </onCancelMovie>
            
    </ClientMethods>

    <LoDLevels>
    </LoDLevels>

</root>
