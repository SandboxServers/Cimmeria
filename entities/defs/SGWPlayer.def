      </onCraftingRespecPrompt>
      
      <onTrainerOpen>
        <Arg>	INT32   <ArgName>TrainerID</ArgName></Arg>	<!-- ID of the trainer we're interacting with -->
        <Arg> ARRAY <of> TrainerAbility </of> <ArgName> Abilities </ArgName> </Arg>
        <Arg>   INT32   <ArgName>CostToRespec</ArgName></Arg>  <!-- Cost to respec abilities, in Naq -->
      </onTrainerOpen>
      
      <onLootDisplay>
      	<Arg>	INT32   <ArgName>EntityID</ArgName></Arg>	<!-- Mob ID of who's loot this is -->
      	<Arg> 	LootItemQuantityList<ArgName>ItemList</ArgName></Arg>	<!-- List of Loot -->
      	<Arg>	INT8 	<ArgName>Initial</ArgName></Arg>	<!-- Is this an update or initial loot window? -->
      </onLootDisplay>
      
      <!-- called by the cell when the player has sent all its data to the client -->
      <onPlayerDataLoaded/>

      <!-- Called by the cell when we teleport anywhere.
	   Causes the client to force a waiting state flag.
	   Needs to have position with message, otherwise the streaming level
	   loading code will not know which chunks to wait for.
	-->
      <onPlayerTeleport>
        <Arg> VECTOR3 <ArgName>Location</ArgName></Arg>
        <Arg> VECTOR3 <ArgName>Direction</ArgName></Arg>
      </onPlayerTeleport>

