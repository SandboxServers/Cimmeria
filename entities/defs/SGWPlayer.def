            <Arg>   INT32  <ArgName> aDestinationId </ArgName>  </Arg> <!-- Generic region destination -->
        </setRingTransporterDestination>
        
        <!-- called when a fellow squad member uses a ring transporter -->
        <onSquadMemberRingTransport>
            <Arg>   INT32   </Arg> <!-- Generic region they entered -->
