        </gmGotoCallback>
        
	<!-- Called by client when it wants to respond to a server challenge -->        
	<onClientChallengeResponse>
		<Exposed/>
		<Arg> INT32 <ArgName>aClientChallenge</ArgName></Arg>
		<Arg> WSTRING <ArgName>aClientVersion</ArgName></Arg>
		<Arg> INT32 <ArgName>aChallengeType</ArgName></Arg>
		<Arg> WSTRING <ArgName>aChallengeObject</ArgName></Arg>
		<Arg> INT32 <ArgName>aChallengeID1</ArgName></Arg>
		<Arg> INT32 <ArgName>aChallengeID2</ArgName></Arg>
		<Arg> WSTRING <ArgName>aChallengeValue</ArgName></Arg>
	</onClientChallengeResponse>
	
        <showPlayer>
            <Arg>       MAILBOX    </Arg> <!-- Base mailbox of the GM calling this -->
        </showPlayer>
        
        <sendDuelChallenge>
            <Arg>    MAILBOX   </Arg> <!-- entity mailbox -->
            <Arg>    INT8      </Arg> <!-- squad duel -->
        </sendDuelChallenge>

